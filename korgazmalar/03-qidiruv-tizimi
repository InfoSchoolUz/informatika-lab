<!DOCTYPE html>
<html lang="uz">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1"/>
<title>Qidiruv Tizimi</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&family=JetBrains+Mono:wght@400;700&display=swap');
*{margin:0;padding:0;box-sizing:border-box}
body{background:#000a05;color:#e2e8f0;font-family:'Inter',sans-serif;height:100vh;overflow:hidden;display:flex;flex-direction:column}
canvas#bg{position:fixed;inset:0;z-index:0}

.ui{position:relative;z-index:1;display:flex;flex-direction:column;height:100vh;padding:12px 14px}

/* Header */
.hdr{text-align:center;margin-bottom:10px}
.hdr-badge{font-size:8px;color:#22c55e55;letter-spacing:4px}
.hdr h1{font-size:1.3rem;font-weight:800;color:#fff;text-shadow:0 0 24px #22c55e44}
.hdr p{font-size:.75rem;color:#475569}

/* Search bar */
.search-wrap{display:flex;gap:8px;margin-bottom:12px}
.search-box{flex:1;display:flex;align-items:center;gap:8px;background:rgba(5,20,10,.9);
  border:1.5px solid #1a4a2a;border-radius:12px;padding:0 14px;transition:border-color .2s}
.search-box:focus-within{border-color:#22c55e;box-shadow:0 0 20px rgba(34,197,94,.15)}
.search-icon{color:#22c55e;font-size:14px}
#search-inp{flex:1;background:transparent;border:none;outline:none;color:#e2e8f0;
  font-family:'Inter',sans-serif;font-size:14px;padding:11px 0}
#search-btn{padding:11px 18px;background:rgba(34,197,94,.1);border:1.5px solid #22c55e55;
  border-radius:10px;color:#22c55e;font-size:13px;cursor:pointer;font-family:'Inter',sans-serif;
  font-weight:700;transition:all .2s;white-space:nowrap}
#search-btn:hover{background:rgba(34,197,94,.2)}
#search-btn.stop{background:rgba(26,6,6,.9);border-color:#ef444455;color:#ef4444}

/* Main area */
.main{flex:1;display:grid;grid-template-columns:1fr 1fr;gap:10px;min-height:0}
@media(max-width:500px){.main{grid-template-columns:1fr}}

/* Left: Web graph */
.graph-panel{background:rgba(5,15,8,.85);border:1px solid #1a4a2a;border-radius:14px;
  padding:12px;display:flex;flex-direction:column;overflow:hidden}
.panel-title{font-size:8px;color:#22c55e;letter-spacing:3px;margin-bottom:8px;font-weight:700}
canvas#graph{flex:1;border-radius:8px;min-height:0}

/* Right: Steps + Results */
.right{display:flex;flex-direction:column;gap:10px;min-height:0}

/* Stage panel */
.stage-panel{background:rgba(5,15,8,.85);border:1px solid #1a4a2a;border-radius:14px;padding:12px}
.stages{display:flex;flex-direction:column;gap:6px}
.stage{display:flex;align-items:center;gap:10px;padding:7px 10px;border-radius:8px;
  border:1px solid #0f2a16;transition:all .4s;opacity:.35}
.stage.active{opacity:1;background:rgba(34,197,94,.07);border-color:#22c55e44}
.stage.done{opacity:.7;background:rgba(34,197,94,.04);border-color:#1a4a2a}
.stage-icon{width:28px;height:28px;border-radius:50%;display:flex;align-items:center;justify-content:center;
  font-size:13px;flex-shrink:0;border:1.5px solid #1a4a2a;transition:all .4s}
.stage.active .stage-icon{border-color:#22c55e;box-shadow:0 0 14px rgba(34,197,94,.5);background:rgba(34,197,94,.1)}
.stage.done .stage-icon{border-color:#22c55e88;background:rgba(34,197,94,.08)}
.stage-info{flex:1}
.stage-name{font-size:.78rem;font-weight:700;color:#94a3b8;transition:color .3s}
.stage.active .stage-name{color:#e2e8f0}
.stage-desc{font-size:.68rem;color:#334155;transition:color .3s;line-height:1.4}
.stage.active .stage-desc{color:#64748b}
.stage-bar{height:2px;background:#0f2a16;border-radius:1px;margin-top:5px;overflow:hidden}
.stage-fill{height:100%;background:linear-gradient(90deg,#22c55e,#34d399);width:0%;transition:width .8s ease;border-radius:1px}

/* Results */
.results-panel{background:rgba(5,15,8,.85);border:1px solid #1a4a2a;border-radius:14px;
  padding:12px;flex:1;overflow:hidden;display:flex;flex-direction:column;min-height:0}
.results-list{flex:1;overflow-y:auto;display:flex;flex-direction:column;gap:6px}
.res-item{background:rgba(10,30,15,.6);border:1px solid #1a4a2a;border-radius:10px;
  padding:9px 12px;animation:slideIn .4s ease;transform-origin:top}
@keyframes slideIn{from{opacity:0;transform:translateY(-8px)}to{opacity:1;transform:none}}
.res-url{font-size:.68rem;color:#22c55e;font-family:'JetBrains Mono',monospace;margin-bottom:3px}
.res-title{font-size:.82rem;font-weight:700;color:#e2e8f0;margin-bottom:2px}
.res-snippet{font-size:.7rem;color:#64748b;line-height:1.4}
.res-score{display:inline-block;background:rgba(34,197,94,.1);border:1px solid #22c55e33;
  border-radius:4px;padding:1px 6px;font-size:.65rem;font-family:'JetBrains Mono',monospace;color:#22c55e;margin-top:4px}
.empty-res{text-align:center;color:#1e3a2a;font-size:.8rem;padding:20px 0}

/* Progress dots */
.dots{display:flex;justify-content:center;gap:6px;margin-top:8px}
.dot{width:7px;height:7px;border-radius:50%;background:#0f2a16;transition:all .3s}
.dot.done{background:#22c55e}
.dot.cur{background:#22c55e88;box-shadow:0 0 10px #22c55e}
</style>
</head>
<body>
<canvas id="bg"></canvas>
<div class="ui">
  <div class="hdr">
    <div class="hdr-badge">◉ 03-KO'RGAZMA · 5-SINF</div>
    <h1>🔍 Qidiruv Tizimi Qanday Ishlaydi?</h1>
    <p>Google, Yandex, Bing — ichida nima sodir bo'ladi</p>
  </div>

  <div class="search-wrap">
    <div class="search-box">
      <span class="search-icon">🔍</span>
      <input id="search-inp" placeholder="qidiruv so'zini kiriting..." value="Urgench maktablari" autocomplete="off"/>
    </div>
    <button id="search-btn" onclick="startSearch()">▶ IZLA</button>
  </div>

  <div class="main">
    <!-- Web graph -->
    <div class="graph-panel">
      <div class="panel-title">🌐 INTERNET TARMOG'I — VEBSAYTLAR</div>
      <canvas id="graph"></canvas>
    </div>

    <!-- Right column -->
    <div class="right">
      <!-- Stages -->
      <div class="stage-panel">
        <div class="panel-title">⚡ QIDIRUV BOSQICHLARI</div>
        <div class="stages" id="stages">
          <div class="stage" id="s0">
            <div class="stage-icon">🕷️</div>
            <div class="stage-info">
              <div class="stage-name">Crawler (O'rgimchak)</div>
              <div class="stage-desc">Barcha saytlarni aylanib chiqadi</div>
              <div class="stage-bar"><div class="stage-fill" id="f0"></div></div>
            </div>
          </div>
          <div class="stage" id="s1">
            <div class="stage-icon">📚</div>
            <div class="stage-info">
              <div class="stage-name">Indekslash</div>
              <div class="stage-desc">So'zlarni katta lug'atga yozadi</div>
              <div class="stage-bar"><div class="stage-fill" id="f1"></div></div>
            </div>
          </div>
          <div class="stage" id="s2">
            <div class="stage-icon">⚖️</div>
            <div class="stage-info">
              <div class="stage-name">Ranking (Baholash)</div>
              <div class="stage-desc">Eng mos saytlarni tanlaydi</div>
              <div class="stage-bar"><div class="stage-fill" id="f2"></div></div>
            </div>
          </div>
          <div class="stage" id="s3">
            <div class="stage-icon">📋</div>
            <div class="stage-info">
              <div class="stage-name">Natijalar</div>
              <div class="stage-desc">Siz uchun tartiblab ko'rsatadi</div>
              <div class="stage-bar"><div class="stage-fill" id="f3"></div></div>
            </div>
          </div>
        </div>
      </div>

      <!-- Results -->
      <div class="results-panel">
        <div class="panel-title">📋 QIDIRUV NATIJALARI</div>
        <div class="results-list" id="results">
          <div class="empty-res">▶ IZLA tugmasini bosing</div>
        </div>
      </div>
    </div>
  </div>

  <div class="dots" id="dots"></div>
</div>

<script>
// ── Background particle web ────────────────────────────────────────────────
const bgc = document.getElementById('bg');
const bx = bgc.getContext('2d');
let bgW, bgH, bgPts = [];
function resizeBg(){
  bgW=bgc.width=innerWidth; bgH=bgc.height=innerHeight;
}resizeBg(); window.addEventListener('resize',resizeBg);
function initBgPts(){
  bgPts=[];
  for(let i=0;i<60;i++) bgPts.push({x:Math.random()*bgW,y:Math.random()*bgH,vx:(Math.random()-.5)*.15,vy:(Math.random()-.5)*.15});
}initBgPts();
function animBg(){
  requestAnimationFrame(animBg);
  bx.clearRect(0,0,bgW,bgH);
  bgPts.forEach(p=>{
    p.x+=p.vx; p.y+=p.vy;
    if(p.x<0)p.x=bgW; if(p.x>bgW)p.x=0;
    if(p.y<0)p.y=bgH; if(p.y>bgH)p.y=0;
  });
  bgPts.forEach((a,i)=>bgPts.slice(i+1).forEach(b=>{
    const d=Math.hypot(a.x-b.x,a.y-b.y);
    if(d<120){bx.beginPath();bx.moveTo(a.x,a.y);bx.lineTo(b.x,b.y);
      bx.strokeStyle=`rgba(34,197,94,${.04*(1-d/120)})`;bx.stroke();}
  }));
  bgPts.forEach(p=>{bx.beginPath();bx.arc(p.x,p.y,1.5,0,Math.PI*2);bx.fillStyle='rgba(34,197,94,.2)';bx.fill();});
}animBg();

// ── Graph canvas ───────────────────────────────────────────────────────────
const gc=document.getElementById('graph');
const gx=gc.getContext('2d');
let gNodes=[],gLinks=[],crawlerPos=0,crawlerPath=[],crawling=false;
const SITES=[
  {label:'google.com',color:'#22c55e'},
  {label:'maktab.uz',color:'#3b82f6'},
  {label:'ziyonet.uz',color:'#a78bfa'},
  {label:'kun.uz',color:'#f59e0b'},
  {label:'edu.uz',color:'#06b6d4'},
  {label:'uzb.wiki',color:'#ec4899'},
  {label:'youtube.com',color:'#ef4444'},
  {label:'sinf.uz',color:'#34d399'},
];

function initGraph(){
  const r=document.getElementById('graph').parentElement;
  gc.width=r.clientWidth-24; gc.height=r.clientHeight-40;
  const cx=gc.width/2, cy=gc.height/2, rad=Math.min(cx,cy)*.75;
  gNodes=SITES.map((s,i)=>{
    const a=(i/SITES.length)*Math.PI*2-Math.PI/2;
    return {x:cx+rad*Math.cos(a),y:cy+rad*Math.sin(a),label:s.label,color:s.color,visited:false,r:22};
  });
  gLinks=[];
  [[0,1],[0,2],[1,3],[1,4],[2,5],[3,6],[4,7],[5,6],[2,4],[0,7],[3,5]].forEach(([a,b])=>gLinks.push({a,b}));
  crawlerPath=[0,1,3,6,5,2,4,7,0];
  crawlerPos=0;
  drawGraph();
}

function drawGraph(){
  gx.clearRect(0,0,gc.width,gc.height);
  gLinks.forEach(l=>{
    const a=gNodes[l.a],b=gNodes[l.b];
    gx.beginPath();gx.moveTo(a.x,a.y);gx.lineTo(b.x,b.y);
    gx.strokeStyle='rgba(34,197,94,.12)';gx.lineWidth=1;gx.stroke();
  });
  gNodes.forEach((n,i)=>{
    gx.beginPath();gx.arc(n.x,n.y,n.r,0,Math.PI*2);
    gx.fillStyle=n.visited?n.color+'33':'rgba(10,30,15,.8)';
    gx.fill();
    gx.strokeStyle=n.visited?n.color:'rgba(34,197,94,.2)';
    gx.lineWidth=n.visited?2:1;gx.stroke();
    gx.fillStyle=n.visited?n.color:'#334155';
    gx.font='bold 7px Inter';gx.textAlign='center';gx.textBaseline='middle';
    gx.fillText(n.label,n.x,n.y);
  });
}

function animateCrawler(progress){
  if(!gNodes.length)return;
  drawGraph();
  const idx=Math.floor(progress*crawlerPath.length);
  for(let i=0;i<=idx&&i<crawlerPath.length;i++) gNodes[crawlerPath[i]].visited=true;
  // Crawler dot
  if(idx<crawlerPath.length){
    const ni=gNodes[crawlerPath[Math.min(idx,crawlerPath.length-1)]];
    gx.beginPath();gx.arc(ni.x,ni.y,ni.r+5,0,Math.PI*2);
    gx.strokeStyle='#22c55e';gx.lineWidth=2;
    gx.setLineDash([4,3]);gx.stroke();gx.setLineDash([]);
    // Pulse
    gx.beginPath();gx.arc(ni.x,ni.y,ni.r+10+Math.sin(Date.now()*.005)*4,0,Math.PI*2);
    gx.strokeStyle='rgba(34,197,94,.3)';gx.lineWidth=1;gx.stroke();
  }
}

// ── Search simulation ──────────────────────────────────────────────────────
let running=false,timers=[];
function T(fn,ms){const id=setTimeout(fn,ms);timers.push(id);}
function clearAll(){timers.forEach(clearTimeout);timers=[];}

const FAKE_RESULTS=[
  {url:'maktab.uz/urgench',title:'Urgench maktablari — rasmiy ro\'yxat',snippet:'Urgench shahrida 42 ta umumta\'lim maktabi faoliyat yuritadi. Ro\'yxat va manzillar...',score:98},
  {url:'edu.uz/urgench-schools',title:'Xorazm viloyati ta\'lim bo\'limi',snippet:'Urgenchdagi maktablar haqida batafsil ma\'lumot, o\'qituvchilar soni...',score:91},
  {url:'uzb.wiki/urgench',title:'Urgench — Wikipedia',snippet:'Urgench — O\'zbekistonning Xorazm viloyatidagi shahar. Aholisi 200 000 dan ortiq...',score:85},
  {url:'kun.uz/news/urgench-school',title:'Urgenchda yangi maktab ochildi',snippet:'2026-yil yanvar oyida Urgenchning yangi zamonaviy maktabi o\'z eshiklarini ochdi...',score:79},
];

function setStage(i,progress=0){
  for(let j=0;j<4;j++){
    const el=document.getElementById('s'+j);
    el.className='stage'+(j<i?' done':j===i?' active':'');
    document.getElementById('f'+j).style.width=(j<i?'100':j===i?Math.round(progress*100):'0')+'%';
  }
}

function buildDots(cur){
  const d=document.getElementById('dots');
  d.innerHTML='';
  for(let i=0;i<4;i++){
    const dot=document.createElement('div');
    dot.className='dot'+(i<cur?' done':i===cur?' cur':'');
    d.appendChild(dot);
  }
}

function startSearch(){
  if(running){stopSearch();return;}
  const q=document.getElementById('search-inp').value.trim();
  if(!q)return;
  running=true;
  document.getElementById('search-btn').textContent='■ TO\'XTAT';
  document.getElementById('search-btn').className='stop';
  document.getElementById('results').innerHTML='';
  gNodes.forEach(n=>n.visited=false);
  setStage(-1);buildDots(-1);

  // Stage 0: Crawler
  setStage(0,0);buildDots(0);
  let t=0,crawlInt=setInterval(()=>{
    t+=.02;animateCrawler(Math.min(t,1));
    setStage(0,Math.min(t,1));
    if(t>=1){clearInterval(crawlInt);
      // Stage 1: Indexing
      T(()=>{setStage(1,0);buildDots(1);
        let t2=0,idxInt=setInterval(()=>{t2+=.025;setStage(1,Math.min(t2,1));
          if(t2>=1){clearInterval(idxInt);
            // Stage 2: Ranking
            T(()=>{setStage(2,0);buildDots(2);
              let t3=0,rkInt=setInterval(()=>{t3+=.03;setStage(2,Math.min(t3,1));
                if(t3>=1){clearInterval(rkInt);
                  // Stage 3: Results
                  T(()=>{setStage(3,0);buildDots(3);
                    let t4=0,resInt=setInterval(()=>{t4+=.04;setStage(3,Math.min(t4,1));
                      if(t4>=1){clearInterval(resInt);showResults(q);running=false;
                        document.getElementById('search-btn').textContent='▶ IZLA';
                        document.getElementById('search-btn').className='';
                      }
                    },40);
                  },300);
                }
              },40);
            },300);
          }
        },40);
      },300);
    }
  },30);
  timers.push(crawlInt);
}

function showResults(q){
  const list=document.getElementById('results');list.innerHTML='';
  FAKE_RESULTS.forEach((r,i)=>{
    setTimeout(()=>{
      const d=document.createElement('div');d.className='res-item';
      const hi=txt=>txt.replace(new RegExp(q.split(' ')[0],'gi'),m=>`<span style="color:#22c55e;font-weight:700">${m}</span>`);
      d.innerHTML=`<div class="res-url">🔗 ${r.url}</div>
        <div class="res-title">${hi(r.title)}</div>
        <div class="res-snippet">${hi(r.snippet)}</div>
        <span class="res-score">★ ${r.score}% mos</span>`;
      list.appendChild(d);
    },i*250);
  });
}

function stopSearch(){
  clearAll();running=false;
  document.getElementById('search-btn').textContent='▶ IZLA';
  document.getElementById('search-btn').className='';
  setStage(-1);buildDots(-1);
  gNodes.forEach(n=>n.visited=false);drawGraph();
  document.getElementById('results').innerHTML='<div class="empty-res">▶ IZLA tugmasini bosing</div>';
}

document.getElementById('search-inp').addEventListener('keydown',e=>e.key==='Enter'&&!running&&startSearch());

window.addEventListener('resize',()=>setTimeout(initGraph,100));
setTimeout(initGraph,50);
</script>
</body>
</html>
